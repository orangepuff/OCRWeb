<configuration>
	<packageSources>
		<clear />
		<add key="NuGet" value="https://api.nuget.org/v3/index.json" />
		<!-- Temporary bridge until Diagnostics.* is published to nuget.org (see DiagnosticLog repo):
		     packages are restored from the local dotnet-pack output of D:\DiagnosticLog. Remove this
		     source (and re-pin the Version in Directory.Packages.props) once the real publish happens. -->
		<add key="DiagnosticLogLocal" value="D:\DiagnosticLog\artifacts" />
	</packageSources>
</configuration>