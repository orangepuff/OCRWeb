# Docker Compose secrets template. Copy to .env (git-ignored) and fill in real values.
# See docs/Authentication/prepare-for-dev.docx for where each value comes from.

# Google Cloud Console -> Clients -> OCRWebBffDev
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RS256 internal token keypair (Bff <-> API only). Safe to regenerate per machine —
# see docs/Authentication/prepare-for-dev.docx §4 for the generation script.
INTERNAL_TOKEN_PRIVATE_KEY=
INTERNAL_TOKEN_PUBLIC_KEY=
