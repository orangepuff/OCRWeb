/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "declarationMap": false
  },
  "angularCompilerOptions": {
    // "full" (not the default "partial") — this library is only ever consumed locally via
    // a file: dependency at the exact same Angular version, and Vite's dependency
    // pre-bundling doesn't reliably apply the Angular Linker step partial output needs to
    // symlinked local packages, which broke DI (NG0203) at runtime.
    "compilationMode": "full"
  }
}
